<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png?v=20260721" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg?v=20260721" />
    <link rel="shortcut icon" href="/favicon/favicon.ico?v=20260721" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png?v=20260721" />
    <meta name="apple-mobile-web-app-title" content="G.M MKC" />
    <link rel="manifest" href="/favicon/site.webmanifest?v=20260721" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
     integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" 
     crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/register.css">
</head>
<body>
    <header>
        <img class="logo" src="/mkc-logo.jpg" alt="MKC Logo">

        <nav>
            <a href="/register/adminSignup" target="register">Register</a>
            <a href="/register/login" target="login">Log In</a>
            <a href="/feedPage/">
                <i class="fa-solid fa-house"></i>
                Home
            </a>
        </nav>
    </header>

    <div class="welcome">
        <h2>welcome to FaithHub</h2>
        <i class="fa-solid fa-cross"></i>
        <p>እሺ ብላችሁ ብትታዘዙኝ ምድር የምታስገኘውን በረከት ትበላላችሁ፤ — ኢሳይያስ 1:19</p>
        <p>Isaiah 1¹⁹ If you be willing and obedient, you shall eat the good of the land.</p>
    </div>
    
    <form action="/register/signup" method="post">
        <h1>Create an Account</h1>
        <% if (locals.messages.errors) { %>
            <% messages.errors.forEach( el => { %>
        <div class="alert alert-danger"><%= el.msg %></div>
            <% }) %>    
        <% } %>
        <label for="username">username</label>
        <input type="text" name="userName" placeholder="User Name" required>
        <label for="email">Email</label>
        <input type="email" name="email" placeholder="Email" required>
        <label for="password">Password</label>
        <input type="password" name="password" placeholder="Password" required>
        <label for="confirmPassword">Confirm password</label>
        <input type="password" name="confirmPassword" placeholder="Confirm Password" required>
        <label for="role">Room</label>
        <select name="role" id="role" required>
            <option value="">Select Room</option>
            <option value="admin">Admin</option>
        </select>
        <button type="submit">Register</button>
        <a href="/register/login" target="login">Already have an account?</a>
    </form>
</body>
</html>