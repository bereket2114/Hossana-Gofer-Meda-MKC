<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Above 18 Youth Membership Management</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <link rel="stylesheet" href="/above18.css">

</head>
<body>

    <div class="search">

        <input id="searchInput" type="text" placeholder="Search member by name...">

        <button onclick="searchMember()">
            <i class="fa-solid fa-magnifying-glass"></i>
            Search
        </button>

  </div>

    <div class="container">

        <h1>G/M/MKC Youth Management > 18</h1>

        <div class="table-container">
            <table>
                <caption class="headA">Age > 18</caption>
                <thead>
                  <tr>
                      <th> Name </th>
                      <th> Age </th>
                      <th> Sex </th>
                      <th> Phone </th>
                      <th> Remove Member </th>
                  </tr>
                </thead>

                <tbody id="youthList" class="youthForm">
                <%  above18Youth.forEach(listA18 => {  %>
                    <tr class="memberList" data-id="<%= listA18._id%>">
                       <td> <%= listA18.youthFullName.toUpperCase() %> </td>
                       <td> <%= listA18.calculatedAge %> </td>
                       <td> <%= listA18.youthGender %> </td>
                       <td> <%= listA18.youthPhone %> </td>
                       <td class="trash">
                            <button class="trashBtn"><i class="fa-solid fa-trash"></i>Delete</button> 
                        </td> 
                    </tr>
                <%  })  %>
          
                </tbody>

            </table>

        </div>

        <div class="amount">
            <p class="amountLabel">TotalYouth Members > 18 </u></p>
            <h2 class="totalNum"><%= amountAbove %></h2>
        </div>

      <div class="back">
        <p>Press the <strong>button</strong> to find those youth age is above 18</p>
        <a href="/youth/under18" target="under_18"  style="text-decoration: none;"> <button type="button"> Back to under 18 </button> </a>
        
      </div>
    </div>
    
    <script type="text/javascript" src="above18Main.js"></script>
     
</body>
</html>